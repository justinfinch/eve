#!/usr/bin/env bash

# direnv loads the devbox-declared environment when you cd into this repo.
# See https://www.jetify.com/docs/devbox/ide_configuration/direnv/

eval "$(devbox generate direnv --print-envrc)"

# Optional: load a local .env file if one exists. Keep .env out of git.
if [ -f .env ]; then
    dotenv .env
fi
